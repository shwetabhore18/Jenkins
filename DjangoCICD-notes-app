pipeline {
    agent { label "node" }

    stages {
        stage("Code") {
            steps {
                echo "this is cloning the code"
                git url: "https://github.com/shwetabhore18/django-notes-app.git", branch:"main"
                echo "COde Cloning successful"
            }
        }

        stage("Build") {
            steps {
                echo "this is building the code"
                sh "docker build -t notes:latest ."
            }
        }

        stage("Test") {
            steps {
                echo "this is testing the code"
            }
        }
        stage("push to dockerhub"){
            steps{
                echo "this is pushing the image to docker hub"
                withCredentials([usernamePassword('credentialsId':"dockerhubcred",
                passwordVariable:"dockerHubPass",
                usernameVariable:"dockerHubUser")]){
                sh "docker login -u ${env.dockerHubUser} -p ${env.dockerHubPass} "
                sh "docker image tag notes:latest ${env.dockerHubUser}/notes:latest"
                sh "docker push ${env.dockerHubUser}/notes:latest"
                }
            }
        }

        stage("Deploy") {
            steps {
                echo "this is deploying the code"
                sh "docker compose up -d"
            }
        }
    }
}
